# --- Open Finance US MCP credentials ---
# Leave blank to inherit from the sibling vima config/.env automatically.
# Set OPENFINANCE_MCP_ENV_FILE to point at a specific dotenv file instead.
OPEN_FINANCE_PARTNER_ID=
OPEN_FINANCE_PARTNER_SECRET=
OPEN_FINANCE_APP_KEY=
OPEN_FINANCE_API_BASE_URL=https://api.finicity.com

# Optional overrides
# OPENFINANCE_MCP_ENV_FILE=/absolute/path/to/.env
# OPEN_FINANCE_VOAI_SLUG=voaHistory
# OPEN_FINANCE_PSI_SETTLE_DAYS=3
